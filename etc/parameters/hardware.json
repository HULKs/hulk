{
  "mujoco_websocket_address": "ws://127.0.0.1:8000",
  "paths": {
    "motions": "etc/motions",
    "neural_networks": "etc/neural_networks",
    "sounds": "etc/sounds",
    "cache": "../.cache/hulk"
  },
  "hsl_network_ports": {
    "game_controller_return": 3939,
    "game_controller_state": 3838,
    "hsl": 10024
  },
  "microphones": {
    "access": "RWInterleaved",
    "format": "S16LE",
    "hardware_device_name": "hw:1,0",
    "number_of_channels": 6,
    "number_of_samples": 1024,
    "number_of_retries": 3,
    "retry_sleep_duration": { "nanos": 0, "secs": 1 },
    "sample_rate": 16000,
    "target_channels": 3
  }
}
