# Unified cross-compilation toolchain for T1 and K1 robots
FROM --platform=linux/amd64 ubuntu:22.04

LABEL maintainer="HULKs"
LABEL description="Cross-compilation toolchain for T1 and K1 robots"
LABEL version="6.1"
LABEL target="k1"

USER root

ENV DEBIAN_FRONTEND=noninteractive

RUN dpkg --add-architecture arm64 && \
    sed -i 's/^deb /deb [arch=amd64] /' /etc/apt/sources.list && \
    { \
        echo 'deb [arch=arm64] http://ports.ubuntu.com/ubuntu-ports jammy main restricted universe multiverse'; \
        echo 'deb [arch=arm64] http://ports.ubuntu.com/ubuntu-ports jammy-updates main restricted universe multiverse'; \
        echo 'deb [arch=arm64] http://ports.ubuntu.com/ubuntu-ports jammy-security main restricted universe multiverse'; \
        echo 'deb [arch=arm64] http://ports.ubuntu.com/ubuntu-ports jammy-backports main restricted universe multiverse'; \
    } > /etc/apt/sources.list.d/ubuntu-ports.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends \
        binutils-aarch64-linux-gnu \
        ca-certificates \
        curl \
        gcc \
        gcc-aarch64-linux-gnu \
        git \
        libc6-dev-arm64-cross \
        libasound2-dev:arm64 \
        libclang-dev \
        libssl-dev \
        libssl-dev:arm64 \
        libstdc++-11-dev-arm64-cross \
        pkg-config && \
    rm -rf \
        /usr/lib/llvm-14/include \
        /usr/lib/llvm-14/lib/*.a \
        /usr/lib/llvm-14/lib/cmake \
        /var/lib/apt/lists/* \
        /usr/share/doc/* \
        /usr/share/info/* \
        /usr/share/lintian/* \
        /usr/share/locale/* \
        /usr/share/man/*

ENV PKG_CONFIG=/usr/bin/pkg-config
ENV PKG_CONFIG_SYSROOT_DIR_aarch64_unknown_linux_gnu="/"
ENV PKG_CONFIG_PATH_aarch64_unknown_linux_gnu="/usr/lib/aarch64-linux-gnu/pkgconfig:/usr/share/pkgconfig:/usr/lib/pkgconfig"
ENV PKG_CONFIG_ALLOW_CROSS=1

# C compiler variables for cc-rs (used by build.rs scripts)
ENV CC_aarch64_unknown_linux_gnu=aarch64-linux-gnu-gcc
ENV AR_aarch64_unknown_linux_gnu=aarch64-linux-gnu-ar

# Install Rust and add the AArch64 target
ENV RUSTUP_TOOLCHAIN=1.95.0
ENV PATH="/root/.cargo/bin:${PATH}"
ENV CARGO_HOME="/root/.cargo"

RUN curl --proto '=https' --tlsv1.2 -sSf --retry 3 https://sh.rustup.rs -o rustup.sh \
    && sh rustup.sh -y \
        --default-toolchain ${RUSTUP_TOOLCHAIN} \
        --profile minimal \
        --target aarch64-unknown-linux-gnu \
    && rm rustup.sh \
    && rm -rf /root/.rustup/downloads /root/.rustup/tmp

COPY cargo-config.toml /root/.cargo/config.toml

ENV BINDGEN_EXTRA_CLANG_ARGS_aarch64_unknown_linux_gnu="\
    --target=aarch64-unknown-linux-gnu \
    --sysroot=/ \
    -I/usr/include \
    -I/usr/include/aarch64-linux-gnu \
    -I/usr/aarch64-linux-gnu/include"

ENV MOLD_VERSION=2.40.4
RUN curl -L https://github.com/rui314/mold/releases/download/v${MOLD_VERSION}/mold-${MOLD_VERSION}-x86_64-linux.tar.gz \
    -o mold.tar.gz && \
    tar -xf mold.tar.gz && \
    mv mold-${MOLD_VERSION}-x86_64-linux/bin/mold /usr/bin/mold && \
    mv mold-${MOLD_VERSION}-x86_64-linux/lib/mold /usr/lib/mold && \
    rm -rf mold.tar.gz mold-${MOLD_VERSION}-x86_64-linux && \
    chmod +x /usr/bin/mold && \
    mkdir -p /usr/libexec/mold && \
    ln -sf /usr/bin/mold /usr/libexec/mold/ld

WORKDIR /workspace
